#!name=比狸比狸过滤
#!desc=本插件覆盖首页热门、首页推荐页、视频详情页和视频页推荐流，可按标题、UP 主、视频 Tag 过滤视频，并清理广告和直播推荐。
#!homepage=https://github.com/dqzboy/Loon_Surge_Rule
#!author=dqzboy

[Script]
首页热门关键词过滤 = type=http-response, pattern=^https:\/\/(?:grpc\.biliapi\.net|app\.bilibili\.com)\/bilibili\.app\.show\.v1\.Popular\/Index$, script-path=https://raw.githubusercontent.com/ElyDemiurge/Loon-Plugins/main/bilibili/JavaScript/Bilibili_filter.js?v=20260506-17, requires-body=true, binary-body-mode=true, argument="[{{{blockedUps}}}, {{{titleKeywords}}}, {{{videoTagKeywords}}}, {{{deepFilter}}}, {{{cleanFeedAds}}}, {{{cleanFeedPromotedVideos}}}, {{{cleanVideoRelatedPromotedContent}}}, {{{cleanVideoRelatedAds}}}, {{{cleanVideoBannerAds}}}, {{{cleanVideoRelatedLiveRecommendations}}}, {{{cleanVideoUpGoodsAds}}}, {{{caseSensitive}}}, {{{notify}}}, {{{logLevel}}}]"

视频页推荐流清理 = type=http-response, pattern=^https:\/\/app\.bilibili\.com\/x\/v2\/feed\/index\/story\?, script-path=https://raw.githubusercontent.com/ElyDemiurge/Loon-Plugins/main/bilibili/JavaScript/Bilibili_filter.js?v=20260506-17, requires-body=true, argument="[{{{blockedUps}}}, {{{titleKeywords}}}, {{{videoTagKeywords}}}, {{{deepFilter}}}, {{{cleanFeedAds}}}, {{{cleanFeedPromotedVideos}}}, {{{cleanVideoRelatedPromotedContent}}}, {{{cleanVideoRelatedAds}}}, {{{cleanVideoBannerAds}}}, {{{cleanVideoRelatedLiveRecommendations}}}, {{{cleanVideoUpGoodsAds}}}, {{{caseSensitive}}}, {{{notify}}}, {{{logLevel}}}]"

首页推荐页关键词过滤 = type=http-response, pattern=^https:\/\/app\.bilibili\.com\/x\/v2\/feed\/index\?, script-path=https://raw.githubusercontent.com/ElyDemiurge/Loon-Plugins/main/bilibili/JavaScript/Bilibili_filter.js?v=20260506-17, requires-body=true, argument="[{{{blockedUps}}}, {{{titleKeywords}}}, {{{videoTagKeywords}}}, {{{deepFilter}}}, {{{cleanFeedAds}}}, {{{cleanFeedPromotedVideos}}}, {{{cleanVideoRelatedPromotedContent}}}, {{{cleanVideoRelatedAds}}}, {{{cleanVideoBannerAds}}}, {{{cleanVideoRelatedLiveRecommendations}}}, {{{cleanVideoUpGoodsAds}}}, {{{caseSensitive}}}, {{{notify}}}, {{{logLevel}}}]"

视频页清理与 Tag 缓存 = type=http-response, pattern=^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.viewunite\.v1\.View\/View$, script-path=https://raw.githubusercontent.com/ElyDemiurge/Loon-Plugins/main/bilibili/JavaScript/Bilibili_filter.js?v=20260506-17, requires-body=true, binary-body-mode=true, argument="[{{{blockedUps}}}, {{{titleKeywords}}}, {{{videoTagKeywords}}}, {{{deepFilter}}}, {{{cleanFeedAds}}}, {{{cleanFeedPromotedVideos}}}, {{{cleanVideoRelatedPromotedContent}}}, {{{cleanVideoRelatedAds}}}, {{{cleanVideoBannerAds}}}, {{{cleanVideoRelatedLiveRecommendations}}}, {{{cleanVideoUpGoodsAds}}}, {{{caseSensitive}}}, {{{notify}}}, {{{logLevel}}}]"

视频页推荐流清理 = type=http-response, pattern=^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.viewunite\.v1\.View\/RelatesFeed$, script-path=https://raw.githubusercontent.com/ElyDemiurge/Loon-Plugins/main/bilibili/JavaScript/Bilibili_filter.js?v=20260506-17, requires-body=true, binary-body-mode=true, argument="[{{{blockedUps}}}, {{{titleKeywords}}}, {{{videoTagKeywords}}}, {{{deepFilter}}}, {{{cleanFeedAds}}}, {{{cleanFeedPromotedVideos}}}, {{{cleanVideoRelatedPromotedContent}}}, {{{cleanVideoRelatedAds}}}, {{{cleanVideoBannerAds}}}, {{{cleanVideoRelatedLiveRecommendations}}}, {{{cleanVideoUpGoodsAds}}}, {{{caseSensitive}}}, {{{notify}}}, {{{logLevel}}}]"

[MITM]
hostname = %APPEND% grpc.biliapi.net, app.bilibili.com, api.bilibili.com

